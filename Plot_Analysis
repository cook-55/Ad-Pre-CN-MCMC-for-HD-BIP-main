# --- Fig 7: CQNLSE uncertainty ---
def plot_fig7_cqnlse_uq(samples_list, rhat_dict, problem, outfile_png, outfile_pdf):
    burn = 1500
    x_grid = problem["x_grid"]
    y_obs = problem["y_obs"]
    solve_cqnlse = problem["solve_cqnlse"]

    fig, axes = plt.subplots(2, 2, figsize=(10, 8))

    # (a) Credible intervals
    ax = axes[0, 0]
    x_pos = np.array([1, 2])
    width = 0.15
    for i, name in enumerate(METHODS):
        if i >= len(samples_list):
            break
        post = samples_list[i][burn:]
        ci = credible_interval(post, ci=0.95)
        mu_a = post[:, 0].mean()
        mu_b = post[:, 1].mean() * 10
        ci_a = ci[0]
        ci_b = ci[1] * 10
        offset = (i - 2) * width
        # Clamp yerr to avoid negative values from skewed posteriors
        yerr_a = [max(0, mu_a - ci_a[0]), max(0, ci_a[1] - mu_a)]
        yerr_b = [max(0, mu_b - ci_b[0]), max(0, ci_b[1] - mu_b)]
        ax.errorbar(x_pos[0] + offset, mu_a,
                    yerr=[[yerr_a[0]], [yerr_a[1]]],
                    fmt=MARKERS[name], color=METHOD_COLORS[name], capsize=4,
                    linewidth=1.2, linestyle='none')
        ax.errorbar(x_pos[1] + offset, mu_b,
                    yerr=[[yerr_b[0]], [yerr_b[1]]],
                    fmt=MARKERS[name], color=METHOD_COLORS[name], capsize=4,
                    linewidth=1.2, linestyle='none')
    ax.axhline(1.0, color='k', linestyle='--', linewidth=1, alpha=0.6, label='True alpha')
    ax.axhline(1.0, color='k', linestyle=':', linewidth=1, alpha=0.6, label='True beta x10')
    ax.set_xticks(x_pos)
    ax.set_xticklabels(['alpha', 'beta (x10)'])
    ax.set_ylabel('Posterior Mean +/- 95% CI')
    ax.legend(frameon=False, fontsize=6, loc='upper left')
    beautify_ax(ax)
    add_panel_label(ax, 'a')

    # (b) Posterior predictive check
    ax = axes[0, 1]
    for i, name in enumerate(METHODS):
        if i >= len(samples_list):
            break
        post = samples_list[i][burn:]
        n_ppc = min(100, len(post))
        indices = np.random.choice(len(post), n_ppc, replace=False)
        predictions = []
        for idx in indices:
            _, u_pred = solve_cqnlse(post[idx, 0], post[idx, 1])
            predictions.append(u_pred.real)
        predictions = np.array(predictions)
        ppc_mean = np.mean(predictions, axis=0)
        ppc_lower = np.percentile(predictions, 2.5, axis=0)
        ppc_upper = np.percentile(predictions, 97.5, axis=0)
        ax.fill_between(x_grid, ppc_lower, ppc_upper, alpha=0.15,
                        color=METHOD_COLORS[name])
        ax.plot(x_grid, ppc_mean, color=METHOD_COLORS[name], linewidth=1.2,
                linestyle=LINESTYLES[name], label=name)
    ax.plot(x_grid, y_obs.real, color='k', linewidth=1.0, linestyle='--',
            label='Observation')
    ax.set_xlabel('Spatial grid')
    ax.set_ylabel('Wave amplitude')
    ax.set_title('Posterior Predictive Check')
    ax.legend(frameon=False, fontsize=6, loc='upper left')
    beautify_ax(ax)
    add_panel_label(ax, 'b')

    # (c) Rhat bar chart
    ax = axes[1, 0]
    rhat_vals = []
    for name in METHODS:
        if name in rhat_dict:
            rhat_vals.append(rhat_dict[name])
        else:
            rhat_vals.append(np.nan)
    x_bar = np.arange(len(METHODS))
    colors_bar = [METHOD_COLORS[m] for m in METHODS]
    ax.bar(x_bar, rhat_vals, width=0.5, color=colors_bar, edgecolor='k', linewidth=0.8)
    ax.axhline(1.05, color='r', linestyle='--', linewidth=1.2, alpha=0.8,
               label='Rhat=1.05 threshold')
    ax.set_xticks(x_bar)
    ax.set_xticklabels([m.replace("Acceptance-Rate Adaptive pCN", "AR-Adaptive pCN")
                        for m in METHODS], rotation=25, ha='right', fontsize=7)
    ax.set_ylabel('Split-Rhat (max)')
    ax.legend(frameon=False, fontsize=7, loc='upper left')
    beautify_ax(ax)
    add_panel_label(ax, 'c')

    # (d) ESS bar chart
    ax = axes[1, 1]
    ess_vals = []
    for i, name in enumerate(METHODS):
        if i >= len(samples_list):
            break
        post = samples_list[i][burn:]
        ess_vals.append(ess_mean(post))
    x_bar = np.arange(len(ess_vals))
    ax.bar(x_bar, ess_vals, width=0.5, color=colors_bar[:len(ess_vals)],
           edgecolor='k', linewidth=0.8)
    ax.set_xticks(x_bar)
    ax.set_xticklabels([m.replace("Acceptance-Rate Adaptive pCN", "AR-Adaptive pCN")
                        for m in METHODS[:len(ess_vals)]], rotation=25, ha='right', fontsize=7)
    ax.set_ylabel('ESS (mean)')
    beautify_ax(ax)
    add_panel_label(ax, 'd')

    plt.savefig(outfile_png)
    plt.savefig(outfile_pdf)
    plt.close(fig)


