# --- Fig 6: CQNLSE diagnostics (2x3) ---
def plot_fig6_cqnlse_diag(samples_list, problem, outfile_png, outfile_pdf):
    from scipy.stats import gaussian_kde
    burn = 1500

    traces_alpha = [s[burn:, 0] for s in samples_list]
    traces_beta = [s[burn:, 1] for s in samples_list]

    def compute_acf(series, max_lag=40):
        n = len(series)
        s = series - series.mean()
        n_fft = 1
        while n_fft < 2 * n:
            n_fft *= 2
        fft_s = np.fft.rfft(s, n=n_fft)
        acf_full = np.fft.irfft(fft_s * np.conj(fft_s))[:n]
        return acf_full[:max_lag+1] / (acf_full[0] + 1e-12)

    acfs_alpha = [compute_acf(tr) for tr in traces_alpha]
    acfs_beta = [compute_acf(tr) for tr in traces_beta]

    fig, axes = plt.subplots(2, 3, figsize=(13, 8))
    for col in range(2):
        ax = axes[0, col]
        tr_list = traces_alpha if col == 0 else traces_beta
        for i, name in enumerate(METHODS):
            if i >= len(tr_list):
                break
            c = METHOD_COLORS[name]
            m = MARKERS[name]
            ls = LINESTYLES[name]
            ax.plot(tr_list[i], color=c, marker=m,
                    markevery=max(1, len(tr_list[i])//60),
                    markersize=3, linestyle=ls, linewidth=1.0,
                    label=name if col == 0 else "", alpha=0.85)
        true_val = 1.0 if col == 0 else 0.1
        ax.axhline(true_val, color='k', linestyle=':', linewidth=1.2, alpha=0.6,
                   label='True' if col == 0 else "")
        ax.set_ylabel(r'$\alpha$' if col == 0 else r'$\beta$')
        ax.set_xlabel('Iteration')
        if col == 0:
            ax.legend(frameon=False, fontsize=6, loc='upper left', ncol=2)
        beautify_ax(ax)
        add_panel_label(ax, chr(97 + col))

    ax = axes[0, 2]
    for i, name in enumerate(METHODS):
        if i >= len(acfs_alpha):
            break
        ax.plot(range(len(acfs_alpha[i])), acfs_alpha[i],
                color=METHOD_COLORS[name], marker=MARKERS[name], markersize=4,
                linestyle=LINESTYLES[name], linewidth=1.2, label=name)
    ax.axhline(0.05, color='gray', linestyle='--', linewidth=0.8, alpha=0.5)
    ax.set_ylabel(r'ACF ($\alpha$)')
    ax.set_xlabel('Lag')
    ax.legend(frameon=False, fontsize=6, loc='upper right')
    beautify_ax(ax)
    add_panel_label(ax, 'c')

    ax = axes[1, 0]
