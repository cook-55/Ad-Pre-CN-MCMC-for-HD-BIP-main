def make_cqnlse_table(cqnlse_chains_all, rhat_dict, burn_c, outfile):
    """Generate CQNLSE results table."""
    rows = []
    for method in METHODS:
        if method not in cqnlse_chains_all:
            continue
        chains = cqnlse_chains_all[method]
        post_all = np.concatenate([ch[burn_c:] for ch in chains], axis=0)
        ess_val = ess_mean(post_all)
        a_est = post_all[:, 0].mean()
        b_est = post_all[:, 1].mean()
        ci = credible_interval(post_all, ci=0.95)
        rows.append([
            method,
            f"{rhat_dict.get(method, 0):.3f}",
            f"{ess_val:.1f}",
            f"{a_est:.4f}",
            f"{abs(a_est - 1.0):.4f}",
            f"{b_est:.4f}",
            f"{abs(b_est - 0.1):.4f}",
            f"[{ci[0,0]:.3f},{ci[0,1]:.3f}]",
            f"[{ci[1,0]:.3f},{ci[1,1]:.3f}]",
        ])
    table_txt = tabulate(
        rows,
        headers=["Method", "Rhat", "ESS", "alpha_est", "|alpha_err|",
                 "beta_est", "|beta_err|", "CI(alpha)", "CI(beta)"],
        tablefmt="grid"
    )
    logprint("\n" + "=" * 100)
    logprint("CQNLSE Results Table")
    logprint("=" * 100)
    logprint(table_txt)
    with open(outfile, "w", encoding="utf-8") as f:
        f.write(table_txt)


