def load_multiseed_results():
    """Load all multi-seed UQ results from checkpoints."""
    n_seeds = load_config().get("n_seeds_uncertainty", 5)
    dim = load_config().get("fixed_dim", 80)
    prob = build_problem_for_exp("IllConditioned", dim)

    all_seed_data = {}
    for method in METHODS:
        all_seed_data[method] = []
        for seed in range(n_seeds):
            ckpt_name = f"{_safe_name(method)}_seed{seed}"
            data = load_checkpoint("multiseed", ckpt_name)
            if data is None:
                continue
            chains = [data["chains"][i] for i in range(data["chains"].shape[0])]
            times = list(data["times"])
            ars = list(data["ars"])
            eval_counts = list(data["eval_counts"])
            burn = int(data["burn"])

            summary = summarize_multichain(
                chains, burn,
                prob["x_true"].cpu().numpy(),
                prob.get("Sigma_true"),
            )
            ess_val = summary["ess_concat"]
            all_seed_data[method].append({
                "ess": ess_val,
                "ess_s": ess_val / max(np.mean(times), 1e-12),
                "ess_eval": ess_val / max(np.mean(eval_counts), 1e-12),
                "rhat": summary["rhat_max"],
                "ar": np.mean(ars),
                "time": np.mean(times),
                "err_mu": summary["err_mu"],
            })

    # Aggregate
    unc_results = []
    for method in METHODS:
        data = all_seed_data[method]
        if not data:
            continue
        unc_results.append({
            "method": method,
            "ESS_mean": np.mean([d["ess"] for d in data]),
            "ESS_std": np.std([d["ess"] for d in data]),
            "ESS_s_mean": np.mean([d["ess_s"] for d in data]),
            "ESS_s_std": np.std([d["ess_s"] for d in data]),
            "ESS_eval_mean": np.mean([d["ess_eval"] for d in data]),
            "ESS_eval_std": np.std([d["ess_eval"] for d in data]),
            "Rhat_mean": np.mean([d["rhat"] for d in data]),
            "Rhat_std": np.std([d["rhat"] for d in data]),
            "AR_mean": np.mean([d["ar"] for d in data]),
            "AR_std": np.std([d["ar"] for d in data]),
            "Time_mean": np.mean([d["time"] for d in data]),
            "Time_std": np.std([d["time"] for d in data]),
            "Err_mu_mean": np.mean([d["err_mu"] for d in data]),
            "Err_mu_std": np.std([d["err_mu"] for d in data]),
        })

    logprint(f"Loaded multiseed results for {len(unc_results)} methods.")
    return unc_results


