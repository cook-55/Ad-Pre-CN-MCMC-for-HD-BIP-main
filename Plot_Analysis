# === TABLE OUTPUT FUNCTIONS ===


def make_table(results_subset, title, outfile):
    """Generate a formatted table from results and save to file."""
    rows = []
    for r in results_subset:
        ci_txt = ""
        if len(r.get("ci", [])) >= 2:
            ci_txt = (
                f"x0={r['ci'][0][1]:.3f}[{r['ci'][0][0]:.3f},{r['ci'][0][2]:.3f}] | "
                f"x1={r['ci'][1][1]:.3f}[{r['ci'][1][0]:.3f},{r['ci'][1][2]:.3f}]"
            )
        rows.append([
            r["exp"], r["dim"], r["method"],
            f"{r['AR']:.3f}",
            f"{r['ESS_concat']:.1f}",
            f"{r['ESS_minchain']:.1f}",
            f"{r['ESS_s']:.3f}",
            f"{r['ESS_eval']:.6f}",
            f"{r['Rhat']:.3f}",
            f"{r['Err_mu']:.3f}",
            f"{r['Err_cov']:.3f}",
            f"{r['Contract']:.3f}",
            f"{r['Time']:.2f}",
            ci_txt,
        ])

    headers = ["Exp", "Dim", "Method", "AR",
               "ESS(concat)", "ESS(minchain)", "ESS/s", "ESS/eval",
               "Rhat", "Err_mu", "Err_cov", "Contract", "Time", "CI(95%)"]
    table_txt = tabulate(rows, headers=headers, tablefmt="grid")

    logprint("\n" + "=" * 120)
    logprint(title)
    logprint("=" * 120)
    logprint(table_txt)

    with open(outfile, "w", encoding="utf-8") as f:
        f.write(table_txt)


