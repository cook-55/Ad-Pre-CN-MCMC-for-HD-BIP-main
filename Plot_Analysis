def plot_fig1(problem, outfile_png, outfile_pdf):
    svals = problem["singular_vals"]
    prior_std = problem["prior_std"]
    dim = problem["dim"]
    if svals is None:
        return

    x = np.arange(1, dim + 1)
    fig, axes = plt.subplots(1, 3, figsize=(10.2, 3.1))

    axes[0].fill_between(x, svals, color="#BDC3C7", alpha=0.20)
    axes[0].plot(x, svals, color="#2C3E50", lw=1.6)
    axes[0].set_title("Forward Spectrum", fontweight="bold")
