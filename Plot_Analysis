def load_checkpoint(category: str, name: str):
    """Load arrays from a checkpoint .npz file. Returns None if not found."""
    path = os.path.join(CKPT_DIR, category, name + ".npz")
    if not os.path.exists(path):
        return None
    return dict(np.load(path, allow_pickle=True))


def load_manifest():
    """Load the checkpoint manifest."""
    path = os.path.join(CKPT_DIR, "manifest.json")
    if os.path.exists(path):
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    logprint(f"WARNING: Manifest not found at {path}")
    logprint("  Did you run generate_data_checkpoint.ipynb first?")
    return {"completed": [], "cqnlse": [], "sensitivity": [], "multiseed": []}


def load_config():
    """Load the experiment configuration."""
    path = os.path.join(OUTDIR, "config_used.json")
    if os.path.exists(path):
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}


def load_lg_result(exp_name, dim, method):
    """Load a single LG result from checkpoint and reconstruct full entry dict."""
    name = f"{_safe_name(exp_name)}_d{dim}_{_safe_name(method)}"
    data = load_checkpoint("lg", name)
    if data is None:
        return None

    chains = [data["chains"][i] for i in range(data["chains"].shape[0])]
    ars = list(data["ars"])
    times = list(data["times"])
    eval_counts = list(data["eval_counts"])
    burn = int(data["burn"])

    # Rebuild problem for summary computation
    prob = build_problem_for_exp(exp_name, dim)
    summary = summarize_multichain(
        chains, burn,
        prob["x_true"].cpu().numpy(),
        prob.get("Sigma_true"),
    )

    ess_val = summary["ess_concat"]
    ess_s = ess_val / max(np.mean(times), 1e-12)
    ess_eval = ess_val / max(np.mean(eval_counts), 1e-12)

    return {
        "exp": exp_name,
        "dim": dim,
        "method": method,
        "AR": float(np.mean(ars)),
        "AR_std": float(np.std(ars)),
        "ESS_concat": float(ess_val),
        "ESS_minchain": float(summary["ess_minchain"]),
        "ESS_s": float(ess_s),
        "ESS_eval": float(ess_eval),
        "Rhat": float(summary["rhat_max"]),
        "Err_mu": float(summary["err_mu"]),
        "Err_cov": float(summary["err_cov"]),
        "Contract": float(summary["contract"]),
        "Time": float(np.mean(times)),
        "Time_std": float(np.std(times)),
        "burn": burn,
        "eval_mean": float(np.mean(eval_counts)),
        "ci": summary["ci"],
        "chains": chains,
        "singular_vals": prob.get("singular_vals"),
        "prior_std": prob["sqrtL"].detach().cpu().numpy()
            if isinstance(prob["sqrtL"], torch.Tensor) else prob["sqrtL"],
    }


def load_all_lg_results():
    """Load all linear-Gaussian results from checkpoints."""
    manifest = load_manifest()
    config = load_config()
    baseline_dims = config.get("baseline_dims", list(range(10, 101, 10)))
    fixed_dim = config.get("fixed_dim", 80)

    exp_dims = {
        "BaselineScan": baseline_dims,
        "WellConditioned": [fixed_dim],
        "IllConditioned": [fixed_dim],
        "LowSNR": [fixed_dim],
        "HighSNR": [fixed_dim],
    }

    results = []
    for exp_name, dims in exp_dims.items():
        for dim in dims:
            for method in METHODS:
                entry = load_lg_result(exp_name, dim, method)
                if entry is not None:
                    results.append(entry)

    logprint(f"Loaded {len(results)} LG results from checkpoints.")
    return results


def load_cqnlse_results():
    """Load all CQNLSE results from checkpoints."""
    set_problem_seed("CQNLSE", 2)
    prob = build_cqnlse()

    dim_c = 2
    N_c = EVAL_BUDGET_CQNLSE - 1
    burn_c = int(N_c * DEFAULT_ADAPT["burn_frac_cqnlse"])

    chains_all = {}
    samples = []
    rhat_dict = {}

    for i, method in enumerate(METHODS):
        ckpt_name = f"CQNLSE_d2_{_safe_name(method)}"
        data = load_checkpoint("cqnlse", ckpt_name)
        if data is None:
            logprint(f"  WARNING: CQNLSE checkpoint not found for {method}")
            continue

        chains = [data["chains"][i] for i in range(data["chains"].shape[0])]
        chains_all[method] = chains
        samples.append(chains[0])

        post_all = np.concatenate([ch[burn_c:] for ch in chains], axis=0)
        rhat_val = split_rhat(np.stack([ch[burn_c:] for ch in chains], axis=0))
        rhat_dict[method] = float(np.max(rhat_val))

    logprint(f"Loaded {len(chains_all)} CQNLSE method results.")
    return chains_all, samples, rhat_dict, prob, burn_c


