# === UTILITY FUNCTIONS ===


def ess_1d(series):
    series = np.asarray(series, dtype=np.float64)
    n = len(series)
    if n < 30:
        return float(max(1, n))
    if np.allclose(series, series[0], atol=1e-12):
        return 1.0
    series = series - series.mean()
    # FFT-based autocorrelation: O(n log n) instead of O(n^2)
    n_fft = 1
    while n_fft < 2 * n:
        n_fft *= 2
    fft_s = np.fft.rfft(series, n=n_fft)
    ac = np.fft.irfft(fft_s * np.conj(fft_s))[:n]
    ac = ac / (ac[0] + 1e-30)
    cutoff = min(n, 4000)
    for k in range(1, cutoff):
        if ac[k] < 0:
            cutoff = k
            break
    tau = 1.0 + 2.0 * np.sum(ac[1:cutoff])
    ess = n / max(tau, 1e-12)
    return float(max(1.0, min(n, ess)))


def ess_mean(samples):
    samples = np.asarray(samples, dtype=np.float64)
    d = samples.shape[1]
    return float(np.mean([ess_1d(samples[:, i]) for i in range(d)]))


def ess_min(samples):
    samples = np.asarray(samples, dtype=np.float64)
    d = samples.shape[1]
    return float(np.min([ess_1d(samples[:, i]) for i in range(d)]))


def split_rhat(chains):
    chains = np.asarray(chains, dtype=np.float64)
    m, n, d = chains.shape
    if n < 50:
        return np.ones(d)
    n2 = n // 2
    split = np.concatenate([chains[:, :n2, :], chains[:, n2:2*n2, :]], axis=0)
    chain_means = split.mean(axis=1)
    chain_vars = split.var(axis=1, ddof=1)
    W = chain_vars.mean(axis=0)
    B = n2 * chain_means.var(axis=0, ddof=1)
    var_hat = ((n2 - 1) / n2) * W + (1 / n2) * B
    Rhat = np.sqrt(var_hat / np.maximum(W, 1e-14))
    return Rhat


def autocorr(x, max_lag=200):
    x = np.asarray(x, dtype=np.float64)
    x = x - x.mean()
    n = len(x)
    if n < 5:
        return np.zeros(max_lag)
    # FFT-based autocorrelation: O(n log n)
    n_fft = 1
    while n_fft < 2 * n:
        n_fft *= 2
    fft_x = np.fft.rfft(x, n=n_fft)
    ac_full = np.fft.irfft(fft_x * np.conj(fft_x))[:n]
    ac = ac_full / (ac_full[0] + 1e-30)
    return ac[:max_lag]


def credible_interval(samples, ci=0.95):
    alpha = 1 - ci
    lower = np.percentile(samples, 100 * alpha / 2, axis=0)
    upper = np.percentile(samples, 100 * (1 - alpha / 2), axis=0)
    return np.column_stack([lower, upper])


def summarize_multichain(chains, burn, x_true_np, Sigma_true):
    """Compute all diagnostics from multiple chains."""
    post_chains = [c[burn:] for c in chains]
    post_all = np.concatenate(post_chains, axis=0)

    mu_est = post_all.mean(axis=0)
    cov_est = np.cov(post_all, rowvar=False)

    err_mu = np.linalg.norm(mu_est - x_true_np) / (np.linalg.norm(x_true_np) + 1e-12)
    err_cov = 0.0
    if Sigma_true is not None and cov_est.ndim == 2:
        err_cov = np.linalg.norm(cov_est - Sigma_true, ord="fro") / \
                  (np.linalg.norm(Sigma_true, ord="fro") + 1e-12)

    ess_concat = ess_mean(post_all)
    ess_chain = [ess_mean(c) for c in post_chains]
    ess_minchain = float(np.min(ess_chain))

    rhat = split_rhat(np.stack(post_chains, axis=0))
    rhat_max = float(np.max(rhat))

    contract = float(np.trace(cov_est) / (np.trace(Sigma_true) + 1e-12)) \
        if Sigma_true is not None else 0.0

    ci = []
    for j in range(min(2, post_all.shape[1])):
        q = np.quantile(post_all[:, j], [0.025, 0.5, 0.975])
        ci.append((float(q[0]), float(q[1]), float(q[2])))

    return {
        "mu_est": mu_est,
        "cov_est": cov_est,
        "err_mu": float(err_mu),
        "err_cov": float(err_cov),
        "ess_concat": float(ess_concat),
        "ess_minchain": float(ess_minchain),
        "rhat_max": float(rhat_max),
        "contract": float(contract),
        "ci": ci,
    }


def _seed_from_key(key: str, base_seed: int = SEED) -> int:
    """Deterministic seed from a string key."""
    h = int(hashlib.md5(f"{key}_{base_seed}".encode()).hexdigest()[:8], 16)
    return h % (2**31)


def _safe_name(name: str) -> str:
    """Convert method/exp name to filesystem-safe string."""
    return name.replace(" ", "_").replace("-", "_").replace(".", "_")


# === PROBLEM BUILDERS (for reconstructing problem data in analysis) ===


def set_problem_seed(exp_name: str, dim: int, base_seed: int = SEED):
    """Set deterministic seeds for problem construction."""
    seed = _seed_from_key(f"problem_{exp_name}_{dim}", base_seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    return seed


def build_linear_gaussian(dim, sigma=0.5, cond_level=20.0, snr_level=1.0):
    """Build a linear-Gaussian inverse problem with controlled spectral structure."""
    sqrtL = torch.linspace(0.5, 4.0, dim, device=DEVICE, dtype=DTYPE)
    invL = 1.0 / (sqrtL ** 2)

    U, _ = torch.linalg.qr(torch.randn(dim, dim, device=DEVICE, dtype=DTYPE))
    V, _ = torch.linalg.qr(torch.randn(dim, dim, device=DEVICE, dtype=DTYPE))
    s = torch.linspace(1.0, 1.0 / cond_level, dim, device=DEVICE, dtype=DTYPE)
    A = U @ torch.diag(s) @ V.T

    x_true = torch.randn(dim, device=DEVICE, dtype=DTYPE) * 0.5
    noise_sigma = sigma / snr_level
    noise = noise_sigma * torch.randn(dim, device=DEVICE, dtype=DTYPE)
    y = A @ x_true + noise

    AtA = A.T @ A
    Aty = A.T @ y
    Precision = AtA / (noise_sigma ** 2) + torch.diag(invL)
    b_vec = Aty / (noise_sigma ** 2)
    x_map = torch.linalg.solve(Precision, b_vec)
    Sigma_true = torch.inverse(Precision).cpu().numpy()

    sig_norm = float(torch.norm(A @ x_true).detach().cpu().item())
    noise_norm = float(torch.norm(noise).detach().cpu().item()) + 1e-30
    snr_db = 20.0 * math.log10(max(sig_norm / noise_norm, 1e-30))

    geom = {
        "cr": float(np.clip(1.0 / cond_level, 0.0, 1.0)),
        "cond": float(cond_level),
        "snr_db": float(snr_db),
    }

    return {
        "sqrtL": sqrtL,
        "invL": invL,
        "A": A,
        "singular_vals": s.detach().cpu().numpy(),
        "AtA": AtA,
        "Aty": Aty,
        "sigma": noise_sigma,
        "x_true": x_true,
        "x0": x_map,
        "Sigma_true": Sigma_true,
        "geom": geom,
        "dim": dim,
        "type": "linear",
    }


def build_cqnlse():
    """Build the CQNLSE inverse problem (d=2)."""
    from scipy.fftpack import fft, ifft

    L_dom = 20
    N_grid = 64
    T_final = 0.5
    nt = 100
    sigma_obs = 0.02
    alpha_true = 1.0
    beta_true = 0.1

    x_grid = np.linspace(-L_dom/2, L_dom/2, N_grid)
    dx = x_grid[1] - x_grid[0]
    k_vec = 2 * np.pi * np.fft.fftfreq(N_grid, dx)
    lin_phase = np.exp(0.5 * 1j * k_vec**2 * (T_final / nt))

    def solve_cqnlse_fwd(alpha, beta):
        u = 1.5 / np.cosh(x_grid)
        for _ in range(nt):
            u = ifft(lin_phase * fft(u))
            u2 = np.abs(u)**2
            nonlin = np.exp(-1j * (alpha * u2 + beta * u2**2) * (T_final / nt))
            u = u * nonlin
            u = ifft(lin_phase * fft(u))
        return x_grid, u

    x_grid_out, u_true = solve_cqnlse_fwd(alpha_true, beta_true)
    y_obs = u_true + sigma_obs * (np.random.randn(*u_true.shape) +
                                    1j * np.random.randn(*u_true.shape))

    prior_mean = np.array([0.8, 0.2])
    prior_std = np.array([0.2, 0.1])
    sqrtL_np = prior_std
    sqrtL_torch = torch.tensor(prior_std, device=DEVICE, dtype=DTYPE)
    invL = 1.0 / (sqrtL_np ** 2)

    return {
        "sqrtL": sqrtL_torch,
        "invL": invL,
        "x_true": torch.tensor([alpha_true, beta_true], device=DEVICE, dtype=DTYPE),
        "x0": torch.tensor(prior_mean, device=DEVICE, dtype=DTYPE),
        "dim": 2,
        "type": "cqnlse",
        "prior_mean": prior_mean,
        "prior_std": prior_std,
        "sigma_obs": sigma_obs,
        "x_grid": x_grid_out,
        "y_obs": y_obs,
        "solve_cqnlse": solve_cqnlse_fwd,
        "geom": {"cond": None, "snr_db": None},
        "singular_vals": None,
        "Sigma_true": None,
    }


def build_problem_for_exp(exp_name, dim):
    """Build the appropriate problem for an experiment name and dimension."""
    set_problem_seed(exp_name, dim)
    configs = {
        "BaselineScan":      (0.5, 20.0, 1.0),
        "WellConditioned":   (0.5, 2.0, 1.0),
        "IllConditioned":    (0.5, 200.0, 1.0),
        "LowSNR":            (0.5, 20.0, 0.35),
        "HighSNR":           (0.5, 20.0, 2.5),
    }
    if exp_name in configs:
        sigma, kappa, snr = configs[exp_name]
        return build_linear_gaussian(dim, sigma=sigma, cond_level=kappa, snr_level=snr)
    elif exp_name == "CQNLSE":
        return build_cqnlse()
    else:
        raise ValueError(f"Unknown experiment: {exp_name}")


